import { NextRequest, NextResponse } from "next/server";
import { requireSession } from "@/lib/auth";
import { db } from "@/lib/db";
import { sendAdminMeetingBooked } from "@/lib/email";

export const dynamic = "force-dynamic";

// POST - the staff member (or an admin) confirms the review meeting is booked
export async function POST(_req: NextRequest, { params }: { params: { cycleId: string } }) {
  const session = await requireSession();
  const cycle = await db.reviewCycle.findUnique({
    where: { id: params.cycleId },
    include: { user: true },
  });
  if (!cycle) return NextResponse.json({ error: "not found" }, { status: 404 });
  if (cycle.userId !== session.userId && session.role !== "ADMIN") {
    const caller = await db.user.findUnique({ where: { id: session.userId } });
    if (!caller?.scheduler) {
      return NextResponse.json({ error: "forbidden" }, { status: 403 });
    }
  }
  if (cycle.meetingBooked) return NextResponse.json({ ok: true, already: true });

  await db.reviewCycle.update({
    where: { id: cycle.id },
    data: { meetingBooked: true, bookedAt: new Date() },
  });

  const admins = await db.user.findMany({
    where: { active: true, OR: [{ role: "ADMIN", reviewNotifications: true }, { scheduler: true }] },
  });
  if (admins.length) {
    await sendAdminMeetingBooked({
      to: admins.map((a) => a.email),
      staffName: cycle.user.name,
    });
  }
  return NextResponse.json({ ok: true });
}
