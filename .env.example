# Database (Neon / Supabase / any Postgres)
DATABASE_URL="postgresql://user:pass@host/norling_reviews?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://reviews.norlinglaw.co.nz"
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"

# Microsoft Entra ID (Azure AD) app registration
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Admins (comma separated) - Brent + Glenn. Anyone else who signs in is Staff.
ADMIN_EMAILS="brent@norlinglaw.co.nz,glenn@norlinglaw.co.nz"

# Email (Resend - swap lib/email.ts for SMTP if preferred)
RESEND_API_KEY=""
EMAIL_FROM="Norling Law Reviews <reviews@norlinglaw.co.nz>"

# Cron protection - Vercel sends this automatically when set in project env
CRON_SECRET="generate a random string"

# App URL used in emails
APP_URL="https://reviews.norlinglaw.co.nz"
